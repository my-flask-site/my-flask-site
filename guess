import random

print("🎮 Welcome to the Number Guessing Game!")
print("I'm thinking of a number between 1 and 10")

number = random.randint(1, 10)
tries = 0

while True:
    guess = int(input("Enter your guess: "))
    tries += 1

    if guess < number:
        print("Too low 📉")
    elif guess > number:
        print("Too high 📈")
    else:
        print("Correct 🎉 You got it!")
        print("You took", tries, "tries")
        break	
